# Copy to .env and fill in real values. Never commit .env.

# ---- OpenAI ----
OPENAI_API_KEY=sk-replace-me
# Chat model used by the conversational agent
OPENAI_CHAT_MODEL=gpt-4o-mini
# Whisper model used for speech-to-text (OpenAI hosted)
OPENAI_WHISPER_MODEL=whisper-1

# ---- Server ----
JARVIS_HOST=0.0.0.0
JARVIS_PORT=8000
# Comma-separated list of allowed CORS origins for the frontend
JARVIS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Storage ----
# SQLite DB file used for task memory & conversation history
JARVIS_DB_PATH=./data/jarvis.db

# ---- Tooling toggles ----
# Set to "false" to disable a tool group entirely
JARVIS_ENABLE_APP_LAUNCHER=true
JARVIS_ENABLE_BROWSER=true
JARVIS_ENABLE_FILE_SUMMARIZER=true
JARVIS_ENABLE_TASK_MEMORY=true

# ---- Browser automation ----
# Headless browser used by the browser tool ("chromium" | "firefox" | "webkit")
JARVIS_BROWSER_ENGINE=chromium
JARVIS_BROWSER_HEADLESS=true

# ---- Frontend ----
# Used by the Vite dev server / Docker build
VITE_API_BASE_URL=http://localhost:8000
